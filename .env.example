# 魔方财务站点根地址（不要以 / 结尾），例如 https://oci.ee
SITE_URL=https://oci.ee

# WebSSH 地址（发 webssh 时回复的链接），默认 https://webssh.oci.ee
# WEBSSH_URL=https://webssh.oci.ee

# Telegram Bot Token（@BotFather 创建）
TELEGRAM_BOT_TOKEN=

# 通知文案（可选，仅用于 Bot 回复的标题）
NOTIFY_HEADER=魔方库存
NOTIFY_SUBTITLE=

# 库存数据缓存时间（秒），有效期内点击不重复拉取，默认 60，最少 30
# CACHE_TTL_SECONDS=60

# 「仅发起人可点键盘」记录：过期时间（秒）、最大条数
# STOCK_ASKER_TTL_SECONDS=3600
# STOCK_ASKER_MAX_SIZE=2000

# 库存键盘消息发出后多少秒自动删除，0=不删，默认 900（15 分钟）
# STOCK_MESSAGE_DELETE_AFTER_SECONDS=900

# 防刷：同一聊天室发库存菜单的冷却（秒），0=不限制，默认 15
# STOCK_CHAT_COOLDOWN_SECONDS=15

# 防刷：官网/webssh/独享 回复的聊天室冷却（秒），0=不限制，默认 10
# SIMPLE_REPLY_COOLDOWN_SECONDS=10

# 代发：仅这些数字 ID 可在「私聊」中用 /say 或 /发群 代发到目标群（逗号分隔）
# TELEGRAM_ADMIN_IDS=123456789

# 代发目标群/频道 chat id（如 -100xxxxxxxxxx），留空关闭代发
# TELEGRAM_ANNOUNCE_CHAT_ID=-1001234567890

# 测试用：--once 时发到指定聊天（你的 chat_id）
# TEST_CHAT_ID=
